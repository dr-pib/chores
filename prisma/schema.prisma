generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id                         Int      @id @default(autoincrement())
  name                       String
  schedule_import_first_name String?
  email                      String?
  email_username             String   @unique
  emt_number                 String   @unique
  licensure_level            String
  role                       String   @default("Employee")
  status                     String   @default("Active")
  default_station_id         Int?
  default_shift_profile_id       Int?     @map("default_crew_post_id")
  default_shift_length_hours Int?     @default(24)
  default_partner_id                Int?
  direct_supervisor_id              Int?
  birthday_month                    Int?
  birthday_day                      Int?
  personal_cell                     String?
  notification_preference           String?  @default("none")
  reminder_hours_before_shift_end   Int?
  created_at                        DateTime @default(now())

  default_partner          Employee?        @relation("EmployeePartner", fields: [default_partner_id], references: [id])
  partner_of               Employee[]       @relation("EmployeePartner")
  direct_supervisor        Employee?        @relation("EmployeeSupervisor", fields: [direct_supervisor_id], references: [id])
  supervised_employees     Employee[]       @relation("EmployeeSupervisor")
  default_station          Station?         @relation("EmployeeDefaultStation", fields: [default_station_id], references: [id])
  default_shift_profile    ShiftProfile?        @relation("EmployeeDefaultShiftProfile", fields: [default_shift_profile_id], references: [id])
  primary_logs             OperationsLog[]  @relation("PrimaryEmployee")
  partner_logs             OperationsLog[]  @relation("PartnerEmployee")
  completed_chores          Chore[]          @relation("ChoreCompletedBy")
  completed_chore_tasks     ChoreTask[]      @relation("ChoreTaskCompletedBy")
  completed_scheduled_work  ScheduledWork[]  @relation("ScheduledWorkCompletedBy")
  supervisor_confirmed_logs OperationsLog[] @relation("SupervisorConfirmedBy")
  change_logs              ChangeLog[]      @relation("ChangeLogChangedBy")
  targeted_change_logs     ChangeLog[]      @relation("ChangeLogTargetEmployee")

  @@map("employees")
}

model Station {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  created_at DateTime @default(now())

  shift_profiles      ShiftProfile[]
  operations_logs OperationsLog[]
  default_employees Employee[] @relation("EmployeeDefaultStation")

  @@map("stations")
}

model Unit {
  id          Int      @id @default(autoincrement())
  unit_number Int      @unique
  unit_type   String
  unit_name   String?
  created_at  DateTime @default(now())

  default_for_shift_profiles ShiftProfile[]
  primary_in_logs            OperationsLog[]    @relation("PrimaryUnit")
  in_bays                    OperationsLogBay[]
  in_chores                  Chore[]            @relation("ChoreUnit")
  in_shift_profile_bays      ShiftProfileBay[]  @relation("ShiftProfileBayUnit")
  in_scheduled_work          ScheduledWork[]

  @@map("units")
}

model ShiftProfile {
  id                         Int      @id @default(autoincrement())
  name                       String   @unique
  station_id                 Int
  default_start_time         String
  default_shift_length_hours Int      @default(24)
  default_unit_id            Int?
  created_at                 DateTime @default(now())

  station           Station         @relation(fields: [station_id], references: [id])
  default_unit      Unit?           @relation(fields: [default_unit_id], references: [id])
  bays              ShiftProfileBay[]
  operations_logs   OperationsLog[]
  default_employees Employee[]      @relation("EmployeeDefaultShiftProfile")

  @@map("crew_posts")
}

model ShiftProfileBay {
  id           Int    @id @default(autoincrement())
  shift_profile_id Int @map("crew_post_id")
  bay_label    String
  unit_id      Int?
  sort_order   Int

  shift_profile ShiftProfile @relation(fields: [shift_profile_id], references: [id])
  unit      Unit?    @relation("ShiftProfileBayUnit", fields: [unit_id], references: [id])

  @@unique([shift_profile_id, bay_label])
  @@map("crew_post_bays")
}

model OperationsLog {
  id                       Int       @id @default(autoincrement())
  service_date             DateTime  @db.Date
  shift_profile_id             Int       @map("crew_post_id")
  station_id               Int
  primary_employee_id      Int
  partner_employee_id      Int?
  primary_unit_id          Int
  actual_start             DateTime
  actual_end               DateTime
  status                   String    @default("submitted")
  supervisor_confirmed_at  DateTime?
  supervisor_confirmed_by_id Int?
  notes                    String?
  chore_date               DateTime? @db.Date
  narc_box_id              Int?
  created_at               DateTime  @default(now())

  shift_profile            ShiftProfile       @relation(fields: [shift_profile_id], references: [id])
  station                  Station            @relation(fields: [station_id], references: [id])
  primary_employee         Employee           @relation("PrimaryEmployee", fields: [primary_employee_id], references: [id])
  partner_employee         Employee?          @relation("PartnerEmployee", fields: [partner_employee_id], references: [id])
  primary_unit             Unit               @relation("PrimaryUnit", fields: [primary_unit_id], references: [id])
  supervisor_confirmed_by  Employee?          @relation("SupervisorConfirmedBy", fields: [supervisor_confirmed_by_id], references: [id])
  narc_box                 NarcBox?           @relation(fields: [narc_box_id], references: [id])
  bays                     OperationsLogBay[]
  chores                   Chore[]
  change_logs              ChangeLog[]
  claimed_scheduled_work   ScheduledWork[]    @relation("ClaimedScheduledWork")

  @@map("operations_logs")
}

model OperationsLogBay {
  id                Int    @id @default(autoincrement())
  operations_log_id Int
  bay_label         String
  unit_id           Int?
  unit_status       String
  sort_order        Int

  operations_log OperationsLog @relation(fields: [operations_log_id], references: [id], onDelete: Cascade)
  unit           Unit?         @relation(fields: [unit_id], references: [id])

  @@unique([operations_log_id, bay_label])
  @@map("operations_log_bays")
}

model ChoreTemplate {
  id                      Int      @id @default(autoincrement())
  name                    String   @unique
  lifecycle_type          String
  due_offset_hours        Float?
  lock_offset_hours       Float?
  asset_scope             String   @default("crew")
  lifecycle               String   @default("forfeitable")
  is_critical             Boolean  @default(false)
  generates_independently Boolean  @default(false)
  station_scope           String?

  chores         Chore[]
  tasks          ChoreTemplateTask[]
  scheduled_work ScheduledWork[]

  @@map("chore_templates")
}

model ChoreTemplateTask {
  id                Int    @id @default(autoincrement())
  chore_template_id Int
  name              String
  sort_order        Int

  chore_template ChoreTemplate @relation(fields: [chore_template_id], references: [id], onDelete: Cascade)
  chore_tasks    ChoreTask[]

  @@map("chore_template_tasks")
}

model Chore {
  id                Int       @id @default(autoincrement())
  operations_log_id Int
  chore_template_id Int
  unit_id           Int?
  bay_label         String?
  status            String    @default("pending")
  due_at            DateTime?
  completed_at      DateTime?
  completed_by_id   Int?
  notes             String?
  chore_date        DateTime? @db.Date
  scheduled_work_id Int?      @unique
  created_at        DateTime  @default(now())

  operations_log OperationsLog  @relation(fields: [operations_log_id], references: [id], onDelete: Cascade)
  chore_template ChoreTemplate  @relation(fields: [chore_template_id], references: [id])
  unit           Unit?          @relation("ChoreUnit", fields: [unit_id], references: [id])
  completed_by   Employee?      @relation("ChoreCompletedBy", fields: [completed_by_id], references: [id])
  scheduled_work ScheduledWork? @relation(fields: [scheduled_work_id], references: [id])
  tasks          ChoreTask[]
  change_logs    ChangeLog[]

  @@map("chores")
}

model ChoreTask {
  id                     Int       @id @default(autoincrement())
  chore_id               Int
  chore_template_task_id Int
  completed_at           DateTime?
  completed_by_id        Int?

  chore               Chore             @relation(fields: [chore_id], references: [id], onDelete: Cascade)
  chore_template_task ChoreTemplateTask @relation(fields: [chore_template_task_id], references: [id])
  completed_by        Employee?         @relation("ChoreTaskCompletedBy", fields: [completed_by_id], references: [id])

  @@map("chore_tasks")
}

model NarcBox {
  id         Int      @id @default(autoincrement())
  letter     String   @unique
  status     String   @default("Active")
  created_at DateTime @default(now())

  operations_logs OperationsLog[]
  scheduled_work  ScheduledWork[]

  @@map("narc_boxes")
}

model ScheduledWork {
  id                Int       @id @default(autoincrement())
  chore_template_id Int
  unit_id           Int?
  narc_box_id       Int?
  asset_type        String
  asset_key         String
  work_date         DateTime  @db.Date
  due_at            DateTime
  claimed_by_log_id Int?
  claimed_at        DateTime?
  status            String    @default("pending")
  resolution_note   String?
  completed_at       DateTime?
  completed_by_id    Int?
  is_late_completion Boolean   @default(false)
  created_at         DateTime  @default(now())

  chore_template ChoreTemplate  @relation(fields: [chore_template_id], references: [id])
  unit           Unit?          @relation(fields: [unit_id], references: [id])
  narc_box       NarcBox?       @relation(fields: [narc_box_id], references: [id])
  claimed_by_log OperationsLog? @relation("ClaimedScheduledWork", fields: [claimed_by_log_id], references: [id])
  completed_by   Employee?      @relation("ScheduledWorkCompletedBy", fields: [completed_by_id], references: [id])
  chore          Chore?

  @@unique([chore_template_id, work_date, asset_type, asset_key])
  @@map("scheduled_work")
}

model ChangeLog {
  id                      Int      @id @default(autoincrement())
  operations_log_id       Int?
  chore_id                Int?
  target_employee_id      Int?
  changed_by_employee_id  Int
  action                  String
  previous_status         String
  new_status              String
  created_at              DateTime @default(now())

  operations_log      OperationsLog? @relation(fields: [operations_log_id], references: [id])
  chore               Chore?         @relation(fields: [chore_id], references: [id])
  target_employee     Employee?      @relation("ChangeLogTargetEmployee", fields: [target_employee_id], references: [id])
  changed_by_employee Employee       @relation("ChangeLogChangedBy", fields: [changed_by_employee_id], references: [id])

  @@map("change_logs")
}
